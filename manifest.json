{
  "manifest_version": 3,
  "name": "Crunchyroll QOL Improvements",
  "version": "1.0.1",
  "description": "Crunchyroll QOL Improvements fixes several frustrating parts of the current Crunchyroll player and adds features that are hard to find in any other extension.",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage"
  ],
  "action": {
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.crunchyroll.com/*",
        "https://crunchyroll.com/*"
      ],
      "js": [
        "settings.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
